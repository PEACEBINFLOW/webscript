// WEBSCRIPT — Pattern 2: Relational Particle
// authored by Peace Thabiwa, SAGEWORKS AI
panel of viewport {
depth   : phi * 300
opacity : field(0.85)
sync    : parent.rhythm
}
sidebar of layout {
width   : viewport.width / phi
height  : viewport.height
depth   : phi * 200
}
content of layout {
width   : viewport.width / phi
padding : phi * 16
}
